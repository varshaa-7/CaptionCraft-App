PORT=5000
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/captioncraft?retryWrites=true&w=majority
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars

# Groq API — get your key at https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# Optional: change the model (default is llama-3.3-70b-versatile)
# Other fast options: mixtral-8x7b-32768 | llama3-8b-8192 | gemma2-9b-it
GROQ_MODEL=llama-3.3-70b-versatile

NODE_ENV=development
